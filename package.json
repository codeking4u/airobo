{
  "name": "looi-robo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "setup": "npm install --legacy-peer-deps",
    "clean": "rm -Force package-lock.json -ErrorAction SilentlyContinue; rm -Force -Recurse node_modules -ErrorAction SilentlyContinue; npm install --legacy-peer-deps",
    "dev": "npx expo start --clear --localhost",
    "dev-no-clear": "npx expo start --localhost",
    "build-local": "npx eas build --platform android --local --wait",
    "build-cloud": "npx eas build --platform android",
    "prebuild": "npx expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "npx expo start --localhost",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@types/react": "~18.0.27",
    "expo": "^55.0.11",
    "expo-cli": "^6.3.12",
    "expo-permissions": "~14.1.1",
    "expo-screen-orientation": "~5.1.1",
    "expo-speech": "~11.1.1",
    "react": "18.2.0",
    "react-native": "^0.71.14"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.18.0",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/metro-config": "^0.84.1",
    "babel-jest": "^29.5.0",
    "jest": "^29.5.0",
    "metro-react-native-babel-preset": "^0.73.9",
    "typescript": "^4.9.5"
  }
}

{
  "expo": {
    "name": "aiRob",
    "slug": "aiRob",
    "version": "1.0.0",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow aiRob to access your photos.",
          "savePhotosPermission": "Allow aiRob to save photos."
        }
      ]
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to listen and chat with Looi Robo."
      }
    }
  }
}
